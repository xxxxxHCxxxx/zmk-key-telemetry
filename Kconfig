menuconfig ZMK_KEY_TELEMETRY
    bool "Enable BLE key/layer telemetry service for companion app"
    depends on ZMK_SPLIT_ROLE_CENTRAL
    depends on BT_PERIPHERAL
    default n

if ZMK_KEY_TELEMETRY

